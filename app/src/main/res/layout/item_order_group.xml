<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvGroupOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order #FPH-1234"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="View Details ▾"
                android:textColor="#FF9800" />
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvInnerItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginVertical="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvGroupLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location: Liloan, Cebu"
                android:textSize="12sp"
                android:textColor="#777777" />

            <TextView
                android:id="@+id/tvGroupRider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rider: Juan Dela Cruz (ID: RIDER-001)"
                android:textSize="12sp"
                android:textColor="#777777" />

            <TextView
                android:id="@+id/tvGroupArrival"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Est. Arrival: 30-45 mins"
                android:textSize="12sp"
                android:textColor="#777777" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total Amount"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvGroupTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textColor="#E91E63"
                android:textStyle="bold"
                android:textSize="18sp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>